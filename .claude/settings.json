{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.py) uv run ruff check --fix \"$f\" && uv run ruff format \"$f\" ;; esac",
            "statusMessage": "Linting and formatting..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_CONFIG_DIR/scripts/check-inbox.sh\"",
            "statusMessage": "Checking coordination inbox..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pip index versions *)",
      "Bash(gh run watch *)"
    ]
  }
}
